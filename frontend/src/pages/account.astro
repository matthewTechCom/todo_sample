---
import Layout from '../layouts/Layout.astro';
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? 'http://localhost:3001';
---

<Layout title="Todo App | Account">
	<div class="page-shell" data-api-base-url={apiBaseUrl}>
		<section class="account-panel">
			<div class="panel-head">
				<div>
					<p class="panel-label">Account</p>
					<h1>アカウント設定</h1>
				</div>
				<button id="logoutButton" class="ghost-button" type="button">ログアウト</button>
			</div>

			<div class="field-list">
				<div class="field">
					<span>メールアドレス</span>
					<strong id="accountEmail">読み込み中...</strong>
				</div>
				<div class="field">
					<span>ユーザーID</span>
					<strong id="accountId">-</strong>
				</div>
			</div>

			<div id="feedback" class="feedback" role="status" aria-live="polite"></div>
		</section>
	</div>

	<script>
		const shell = document.querySelector('.page-shell');
		const apiBaseUrl = shell?.dataset.apiBaseUrl ?? 'http://localhost:3001';
		const cookieKeys = {
			token: 'todo-sample-token',
			user: 'todo-sample-user',
		};

		const accountEmail = document.querySelector('#accountEmail');
		const accountId = document.querySelector('#accountId');
		const feedback = document.querySelector('#feedback');
		const logoutButton = document.querySelector('#logoutButton');

		const setFeedback = (message, kind = 'neutral') => {
			if (!feedback) return;
			feedback.textContent = message;
			feedback.dataset.kind = kind;
		};

		const readCookie = (name) => {
			const prefix = `${name}=`;
			const value =
				document.cookie
					.split('; ')
					.find((row) => row.startsWith(prefix))
					?.slice(prefix.length) ?? null;
			return value ? decodeURIComponent(value) : null;
		};

		const clearCookie = (name) => {
			document.cookie = `${name}=; path=/; max-age=0; SameSite=Lax`;
		};

		const clearSession = () => {
			clearCookie(cookieKeys.token);
			clearCookie(cookieKeys.user);
		};

		const readToken = () => readCookie(cookieKeys.token);
		const readUser = () => {
			const value = readCookie(cookieKeys.user);
			return value ? JSON.parse(value) : null;
		};

		const renderUser = (user) => {
			accountEmail.textContent = user?.email ?? '-';
			accountId.textContent = user?.id ? String(user.id) : '-';
		};

		const redirectToLogin = () => {
			window.location.replace('/');
		};

		const token = readToken();
		if (!token) {
			redirectToLogin();
		}

		const cachedUser = readUser();
		if (cachedUser) {
			renderUser(cachedUser);
			setFeedback('ログイン中のアカウントです。', 'success');
		} else {
			renderUser(null);
			setFeedback('保存済みのアカウント情報がありません。', 'neutral');
		}

		logoutButton?.addEventListener('click', async () => {
			try {
				await fetch(`${apiBaseUrl}/api/v1/auth/logout`, {
					method: 'DELETE',
					headers: {
						Authorization: readToken() ?? '',
					},
				});
			} catch (error) {
				console.error(error);
			} finally {
				clearSession();
				redirectToLogin();
			}
		});

	</script>
</Layout>

<style>
	:root {
		--paper: rgba(255, 251, 245, 0.92);
		--ink: #1a1815;
		--muted: #685f56;
		--line: rgba(64, 48, 32, 0.16);
		--accent-deep: #7b2f1f;
		--success: #2f7a48;
		--error: #a93a2c;
	}

	.page-shell {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		box-sizing: border-box;
		background:
			radial-gradient(circle at top left, rgba(199, 93, 44, 0.22), transparent 38%),
			radial-gradient(circle at right 15%, rgba(97, 58, 27, 0.18), transparent 24%),
			linear-gradient(135deg, #f7f0e6 0%, #efe5d6 54%, #e9dfd0 100%);
		font-family:
			'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', 'Yu Gothic',
			'Meiryo', sans-serif;
		color: var(--ink);
	}

	.account-panel {
		width: min(100%, 560px);
		border: 1px solid var(--line);
		border-radius: 28px;
		backdrop-filter: blur(18px);
		background: linear-gradient(180deg, rgba(255, 251, 246, 0.96), rgba(248, 240, 227, 0.92)),
			var(--paper);
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.panel-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.panel-label {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent-deep);
	}

	h1 {
		margin: 0.35rem 0 0;
		font-size: 2rem;
		letter-spacing: -0.04em;
	}

	.ghost-button {
		padding: 0.85rem 1rem;
		border-radius: 16px;
		border: 1px solid rgba(85, 56, 32, 0.14);
		background: rgba(255, 255, 255, 0.8);
		font: inherit;
		cursor: pointer;
		color: var(--ink);
	}

	.field-list {
		display: grid;
		gap: 0.9rem;
	}

	.field {
		padding: 1rem 1.1rem;
		border-radius: 20px;
		border: 1px solid rgba(97, 58, 27, 0.12);
		background: rgba(255, 255, 255, 0.58);
		display: grid;
		gap: 0.35rem;
	}

	.field span {
		font-size: 0.9rem;
		color: var(--muted);
	}

	.field strong {
		font-size: 1rem;
	}

	.feedback {
		min-height: 1.5rem;
		font-size: 0.95rem;
	}

	.feedback[data-kind='success'] {
		color: var(--success);
	}

	.feedback[data-kind='error'] {
		color: var(--error);
	}

	.feedback[data-kind='neutral'] {
		color: var(--muted);
	}

	@media (max-width: 640px) {
		.page-shell {
			padding: 1rem;
		}

		.account-panel {
			padding: 1.25rem;
		}

		.panel-head {
			flex-direction: column;
		}
	}
</style>
