---
import Layout from '../layouts/Layout.astro';
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? 'http://localhost:3001';
---

<Layout title="Todo App | Login">
	<div class="page-shell" data-api-base-url={apiBaseUrl}>
		<section class="auth-panel">
			<div class="panel-head">
				<div>
					<p class="panel-label">Auth</p>
					<h2>アカウント</h2>
				</div>
				<div class="mode-switch" role="tablist" aria-label="認証モード切替">
					<button id="loginTab" class="mode-button is-active" type="button" data-mode="login">
						ログイン
					</button>
					<button id="signupTab" class="mode-button" type="button" data-mode="signup">
						新規登録
					</button>
				</div>
			</div>

			<form id="loginForm" class="auth-form" novalidate>
				<label>
					<span>メールアドレス</span>
					<input id="loginEmail" name="email" type="email" autocomplete="email" required />
				</label>
				<label>
					<span>パスワード</span>
					<input
						id="loginPassword"
						name="password"
						type="password"
						autocomplete="current-password"
						minlength="6"
						required
					/>
				</label>
				<button class="submit-button" type="submit">ログインする</button>
			</form>

			<form id="signupForm" class="auth-form is-hidden" novalidate>
				<label>
					<span>メールアドレス</span>
					<input id="signupEmail" name="email" type="email" autocomplete="email" required />
				</label>
				<label>
					<span>パスワード</span>
					<input
						id="signupPassword"
						name="password"
						type="password"
						autocomplete="new-password"
						minlength="6"
						required
					/>
				</label>
				<label>
					<span>確認用パスワード</span>
					<input
						id="signupPasswordConfirmation"
						name="passwordConfirmation"
						type="password"
						autocomplete="new-password"
						minlength="6"
						required
					/>
				</label>
				<button class="submit-button" type="submit">アカウントを作成</button>
			</form>

			<div id="feedback" class="feedback" role="status" aria-live="polite"></div>
		</section>
	</div>

	<script>
		const shell = document.querySelector('.page-shell');
		const apiBaseUrl = shell?.dataset.apiBaseUrl ?? 'http://localhost:3001';
		const cookieKeys = {
			token: 'todo-sample-token',
			user: 'todo-sample-user',
		};
		const cookieMaxAge = 60 * 60 * 24 * 7;

		const loginForm = document.querySelector('#loginForm');
		const signupForm = document.querySelector('#signupForm');
		const loginTab = document.querySelector('#loginTab');
		const signupTab = document.querySelector('#signupTab');
		const feedback = document.querySelector('#feedback');

		const showMode = (mode) => {
			const loginActive = mode === 'login';
			loginForm?.classList.toggle('is-hidden', !loginActive);
			signupForm?.classList.toggle('is-hidden', loginActive);
			loginTab?.classList.toggle('is-active', loginActive);
			signupTab?.classList.toggle('is-active', !loginActive);
		};

		const setFeedback = (message, kind = 'neutral') => {
			if (!feedback) return;
			feedback.textContent = message;
			feedback.dataset.kind = kind;
		};

		const parseResponse = async (response) => {
			const contentType = response.headers.get('content-type') ?? '';
			if (contentType.includes('application/json')) {
				return response.json();
			}
			return response.text();
		};

		const authFetch = async (path, options = {}) => {
			const headers = new Headers(options.headers ?? {});
			headers.set('Content-Type', 'application/json');

			const response = await fetch(`${apiBaseUrl}${path}`, {
				...options,
				headers,
			});
			const payload = await parseResponse(response);
			return { response, payload };
		};

		const extractToken = (response, payload) => {
			if (payload && typeof payload === 'object' && payload.token) return payload.token;
			return response.headers.get('Authorization');
		};

		const readCookie = (name) => {
			const prefix = `${name}=`;
			return document.cookie
				.split('; ')
				.find((row) => row.startsWith(prefix))
				?.slice(prefix.length) ?? null;
		};

		const writeCookie = (name, value) => {
			document.cookie =
				`${name}=${encodeURIComponent(value)}; path=/; max-age=${cookieMaxAge}; SameSite=Lax`;
		};

		const persistSession = (token, user) => {
			writeCookie(cookieKeys.token, token);
			writeCookie(cookieKeys.user, JSON.stringify(user));
		};

		loginTab?.addEventListener('click', () => showMode('login'));
		signupTab?.addEventListener('click', () => showMode('signup'));

		loginForm?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const email = document.querySelector('#loginEmail')?.value.trim();
			const password = document.querySelector('#loginPassword')?.value ?? '';

			setFeedback('ログイン中...', 'neutral');
			try {
				const { response, payload } = await authFetch('/api/v1/auth/login', {
					method: 'POST',
					body: JSON.stringify({ user: { email, password } }),
				});

				if (!response.ok) {
					setFeedback('ログインに失敗しました。入力内容を確認してください。', 'error');
					return;
				}

				const token = extractToken(response, payload);
				if (!token || !payload.user) {
					setFeedback('ログイン情報の保存に失敗しました。', 'error');
					return;
				}

				persistSession(token, payload.user);
				window.location.href = '/account';
			} catch (error) {
				setFeedback('ログインAPIへの接続に失敗しました。', 'error');
				console.error(error);
			}
		});

		signupForm?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const email = document.querySelector('#signupEmail')?.value.trim();
			const password = document.querySelector('#signupPassword')?.value ?? '';
			const passwordConfirmation =
				document.querySelector('#signupPasswordConfirmation')?.value ?? '';

			if (password !== passwordConfirmation) {
				setFeedback('パスワードと確認用パスワードが一致しません。', 'error');
				return;
			}

			setFeedback('登録中...', 'neutral');
			try {
				const { response, payload } = await authFetch('/api/v1/auth/signup', {
					method: 'POST',
					body: JSON.stringify({
						user: {
							email,
							password,
							password_confirmation: passwordConfirmation,
						},
					}),
				});

				if (!response.ok) {
					setFeedback('登録に失敗しました。入力内容を確認してください。', 'error');
					return;
				}

				const token = extractToken(response, payload);
				if (!token || !payload.user) {
					setFeedback('登録情報の保存に失敗しました。', 'error');
					return;
				}

				persistSession(token, payload.user);
				window.location.href = '/account';
			} catch (error) {
				setFeedback('登録APIへの接続に失敗しました。', 'error');
				console.error(error);
			}
		});

		showMode('login');

		if (readCookie(cookieKeys.token)) {
			window.location.replace('/account');
		}
	</script>
</Layout>

<style>
	:root {
		--sand: #f3efe5;
		--paper: rgba(255, 251, 245, 0.88);
		--ink: #1a1815;
		--muted: #685f56;
		--line: rgba(64, 48, 32, 0.16);
		--accent: #c75d2c;
		--accent-deep: #7b2f1f;
		--accent-soft: #f7c3a7;
		--success: #2f7a48;
		--error: #a93a2c;
	}

	.page-shell {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		box-sizing: border-box;
		background:
			radial-gradient(circle at top left, rgba(199, 93, 44, 0.22), transparent 38%),
			radial-gradient(circle at right 15%, rgba(97, 58, 27, 0.18), transparent 24%),
			linear-gradient(135deg, #f7f0e6 0%, #efe5d6 54%, #e9dfd0 100%);
		color: var(--ink);
		font-family:
			'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Noto Sans JP', 'Yu Gothic',
			'Meiryo', sans-serif;
	}

	.auth-panel {
		width: min(100%, 520px);
		border: 1px solid var(--line);
		border-radius: 28px;
		backdrop-filter: blur(18px);
		background:
			linear-gradient(180deg, rgba(255, 251, 246, 0.96), rgba(248, 240, 227, 0.92)),
			var(--paper);
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
	}

	.panel-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.panel-head h2 {
		margin: 0.35rem 0 0;
		font-size: 2rem;
		letter-spacing: -0.04em;
	}

	.panel-label {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent-deep);
	}

	.mode-switch {
		display: inline-grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		padding: 0.2rem;
		border-radius: 999px;
		background: rgba(113, 71, 31, 0.08);
		border: 1px solid rgba(113, 71, 31, 0.12);
	}

	.mode-button,
	.submit-button,
	.secondary-button {
		border: none;
		cursor: pointer;
		font: inherit;
	}

	.mode-button {
		padding: 0.7rem 1rem;
		border-radius: 999px;
		background: transparent;
		color: var(--muted);
		transition:
			background 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.mode-button.is-active {
		background: #fff7f1;
		color: var(--accent-deep);
	}

	.auth-form {
		display: grid;
		gap: 0.9rem;
	}

	.auth-form.is-hidden {
		display: none;
	}

	label {
		display: grid;
		gap: 0.45rem;
	}

	label span {
		font-size: 0.92rem;
		color: var(--muted);
	}

	input {
		width: 100%;
		box-sizing: border-box;
		padding: 0.95rem 1rem;
		border-radius: 16px;
		border: 1px solid rgba(85, 56, 32, 0.14);
		background: rgba(255, 255, 255, 0.8);
		font: inherit;
		color: var(--ink);
	}

	input:focus {
		outline: 2px solid rgba(199, 93, 44, 0.25);
		border-color: rgba(199, 93, 44, 0.5);
	}

	.submit-button {
		margin-top: 0.35rem;
		padding: 1rem 1.2rem;
		border-radius: 18px;
		background: linear-gradient(135deg, var(--accent) 0%, #874022 100%);
		color: #fff8f1;
		font-weight: 700;
		letter-spacing: 0.02em;
	}

	.feedback {
		min-height: 1.5rem;
		font-size: 0.95rem;
	}

	.feedback[data-kind='success'] {
		color: var(--success);
	}

	.feedback[data-kind='error'] {
		color: var(--error);
	}

	.feedback[data-kind='neutral'] {
		color: var(--muted);
	}

	@media (max-width: 960px) {
		.page-shell {
			padding: 1rem;
		}

		.auth-panel {
			padding: 1.25rem;
		}
	}

	@media (max-width: 640px) {
		.panel-head {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
